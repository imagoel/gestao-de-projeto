// ============================================================
// Schema Prisma — Sistema de Gestão de Projetos
// Stack: NestJS + Prisma + PostgreSQL
// Deploy: Docker / Portainer
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  MEMBER
}

enum ProjectRole {
  MANAGER   // pode editar o projeto e gerenciar membros
  MEMBER    // pode mover cards e comentar
  VIEWER    // somente leitura
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CardPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// USERS
// ============================================================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(MEMBER)
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relações
  ownedProjects   Project[]       @relation("ProjectOwner")
  projectMembers  ProjectMember[]
  assignedCards   Card[]          @relation("CardAssignee")
  comments        Comment[]
  activityLogs    ActivityLog[]

  @@map("users")
}

// ============================================================
// PROJECTS
// ============================================================

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  deadline    DateTime?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Dono do projeto
  ownerId String @map("owner_id")
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  // Relações
  members      ProjectMember[]
  board        Board?
  activityLogs ActivityLog[]

  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(uuid())
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now()) @map("joined_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId]) // um usuário não pode ser membro duplicado
  @@map("project_members")
}

// ============================================================
// BOARD
// Cada projeto tem exatamente 1 board
// ============================================================

model Board {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  projectId String  @unique @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  columns Column[]

  @@map("boards")
}

// ============================================================
// COLUMNS
// Colunas do Kanban. MVP começa com colunas fixas,
// mas position permite reordenação futura.
// ============================================================

model Column {
  id       String @id @default(uuid())
  title    String
  position Int    // 0, 1, 2... para ordenação

  boardId String @map("board_id")
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]

  @@map("columns")
}

// ============================================================
// CARDS (tarefas)
// ============================================================

model Card {
  id          String       @id @default(uuid())
  title       String
  description String?
  priority    CardPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  archived    Boolean      @default(false)
  position    Int          @default(0) // para ordenação dentro da coluna
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  columnId String @map("column_id")
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  // Responsável (opcional — pode estar sem responsável)
  assigneeId String? @map("assignee_id")
  assignee   User?   @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Relações filhas
  comments       Comment[]
  checklistItems ChecklistItem[]
  labels         CardLabel[]
  activityLogs   ActivityLog[]

  @@map("cards")
}

// ============================================================
// COMMENTS
// ============================================================

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cardId String @map("card_id")
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ============================================================
// CHECKLIST ITEMS
// ============================================================

model ChecklistItem {
  id        String   @id @default(uuid())
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  cardId String @map("card_id")
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ============================================================
// LABELS (etiquetas) — fase 2, mas modelado agora
// ============================================================

model Label {
  id    String @id @default(uuid())
  name  String
  color String // ex: "#FF5733"

  cards CardLabel[]

  @@map("labels")
}

model CardLabel {
  cardId  String @map("card_id")
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  labelId String @map("label_id")
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@map("card_labels")
}

// ============================================================
// ACTIVITY LOG — histórico de ações (fase 2)
// Modelado agora para não exigir retrabalho depois
// ============================================================

model ActivityLog {
  id        String   @id @default(uuid())
  action    String   // ex: "card.moved", "card.created", "comment.added"
  meta      Json?    // dados extras da ação (ex: coluna de/para)
  createdAt DateTime @default(now()) @map("created_at")

  // Autor da ação
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Contexto (um ou outro — nullable)
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  cardId String? @map("card_id")
  card   Card?   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}
